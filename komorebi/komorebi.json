{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.35/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 5,
  "default_container_padding": 5,
  "border": false,
  "border_width": 4,
  "border_offset": -1,
  "border_style": "Rounded",
  "border_colours": {
    "single": "#89b4fa",
    "stack": "#89b4fa",
    "monocle": "#89b4fa",
    "floating": "#89b4fa",
    "unfocused": "#9399b2"
  },
  "stackbar": {
    "height": 20,
    "mode": "OnStack",
    "tabs": {
      "background": "#313244",
      "width": 150,
      "font_size": 20,
      "focused_text": "#89b4fa",
      "unfocused_text": "#cdd6f4"
    }
  },
  "animation": {
    "enabled": true,
    "duration": 250,
    "fps": 60,
    "style": {
      "movement": "EaseOutBack",
      "transparency": "Linear"
    }
  },
  "manage_rules": [
    {
      "kind": "Title",
      "id": "main - hydrus ",
      "matching_strategy": "StartsWith"
    }
  ],
  "ignore_rules": [
    {
      "kind": "Title",
      "id": " - hydrus ",
      "matching_strategy": "Contains"
    },
    {
